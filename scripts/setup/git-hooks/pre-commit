#!/bin/bash
# pre-commit hook: 提交前检查

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${YELLOW}===================================${NC}"
echo -e "${YELLOW}🦞 Pre-commit 检查${NC}"
echo -e "${YELLOW}===================================${NC}"

# 检查行尾空格
echo -n "• 检查行尾空格... "
if git diff --cached --check > /dev/null 2>&1; then
    echo -e "${GREEN}✅ 无行尾空格${NC}"
else
    echo -e "${RED}❌ 发现行尾空格${NC}"
    git diff --cached --check 2>&1
    exit 1
fi

# 检查是否有空提交
echo -n "• 检查空提交... "
if ! git diff-index --cached --quiet HEAD --; then
    echo -e "${GREEN}✅ 有实际修改${NC}"
else
    echo -e "${YELLOW}⚠️  警告：提交为空${NC}"
    echo -e "${YELLOW}提示：使用 git commit --allow-empty 如果确实需要空提交${NC}"
    exit 1
fi

# 检查是否有大文件
echo -n "• 检查大文件 (>100KB)... "
LARGE_FILES=$(git diff --cached --name-only | xargs -I {} sh -c "test -f {} && test \$(stat -f%z {} 2>/dev/null || stat -c%s {} 2>/dev/null) -gt 102400 && echo {}" 2>/dev/null || true)
if [ -n "$LARGE_FILES" ]; then
    echo -e "${RED}❌ 发现大文件:${NC}"
    echo "$LARGE_FILES" | while read -r file; do
        echo "  - $file"
    done
    echo ""
    echo -e "${YELLOW}提示：大文件应使用 Git LFS 管理${NC}"
    exit 1
else
    echo -e "${GREEN}✅ 无大文件${NC}"
fi

# 检查 Python 文件 (如果存在)
if git diff --cached --name-only | grep -q '\.py$'; then
    echo -n "• 检查 Python 语法... "
    if python3 -m py_compile $(git diff --cached --name-only | grep '\.py$') > /dev/null 2>&1; then
        echo -e "${GREEN}✅ Python 语法正确${NC}"
    else
        echo -e "${RED}❌ Python 语法错误${NC}"
        exit 1
    fi
fi

# 检查 Shell 脚本 (如果存在)
if git diff --cached --name-only | grep -q '\.sh$'; then
    echo -n "• 检查 Shell 语法... "
    for file in $(git diff --cached --name-only | grep '\.sh$'); do
        if ! bash -n "$file" > /dev/null 2>&1; then
            echo -e "${RED}❌ Shell 语法错误: $file${NC}"
            exit 1
        fi
    done
    echo -e "${GREEN}✅ Shell 语法正确${NC}"
fi

# 检查 YAML 文件 (如果存在)
if git diff --cached --name-only | grep -q '\.yaml$\|\.yml$'; then
    echo -n "• 检查 YAML 格式... "
    if which python3 > /dev/null 2>&1; then
        for file in $(git diff --cached --name-only | grep '\.yaml$\|\.yml$'); do
            if [ -f "$file" ]; then
                python3 -c "import yaml; yaml.safe_load(open('$file'))" > /dev/null 2>&1 || {
                    echo -e "${RED}❌ YAML 格式错误: $file${NC}"
                    exit 1
                }
            fi
        done
        echo -e "${GREEN}✅ YAML 格式正确${NC}"
    else
        echo -e "${YELLOW}⚠️  跳过 (未安装 Python)${NC}"
    fi
fi

echo ""
echo -e "${GREEN}===================================${NC}"
echo -e "${GREEN}✅ 所有检查通过！${NC}"
echo -e "${GREEN}===================================${NC}"

exit 0
